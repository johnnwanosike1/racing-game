# Force LF for all text files
* text=auto eol=lf

# Unity specific text files
*.cs text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.asset text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.yaml text eol=lf

# Images / binaries
*.png binary
*.jpg binary
*.jpeg binary
*.fbx binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.dll binary